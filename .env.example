# 应用环境配置示例文件
# 复制此文件为 .env 并填入实际配置值

# ===========================================
# 应用基础配置
# ===========================================
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=123456

# ===========================================
# 数据库配置方式一：使用 DATABASE_URL（现有方式兼容）
# ===========================================
DATABASE_URL=postgresql://postgres:postgres123@localhost:15432/commercial_real_estate

# ===========================================
# 数据库配置方式二：分离配置（推荐用于灵活配置）
# ===========================================
# 数据库类型: postgresql | mysql | sqlite | neon
DB_TYPE=postgresql

# PostgreSQL / MySQL 配置
DB_HOST=localhost
DB_PORT=15432
DB_NAME=commercial_real_estate
DB_USER=postgres
DB_PASSWORD=postgres123
DB_SSL=false
DB_POOL_SIZE=10
DB_TIMEOUT=30000
DB_SCHEMA=public

# ===========================================
# Replit 环境变量（自动提供）
# ===========================================
PGHOST=localhost
PGPORT=15432
PGUSER=postgres
PGPASSWORD=postgres123
PGDATABASE=commercial_real_estate

# ===========================================
# 对象存储配置
# ===========================================
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your_bucket_id
# PRIVATE_OBJECT_DIR=/bucket_name/.private
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket_name/public

# ===========================================
# 各环境示例配置
# ===========================================

# 开发环境示例（本地 PostgreSQL）
# NODE_ENV=development
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=store_dev
# DB_USER=postgres
# DB_PASSWORD=dev_password

# 生产环境示例（Neon Cloud）
# NODE_ENV=production
# DB_TYPE=neon
# DATABASE_URL=postgresql://user:pass@neon.tech/dbname?sslmode=require

# 测试环境示例（内存 SQLite）
# NODE_ENV=test
# DB_TYPE=sqlite
# DB_NAME=:memory:

# 企业微信扫码登录
WECOM_ENABLED=true
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id
WECOM_APP_SECRET=your-app-secret
WECOM_REDIRECT_BASE_URL=https://shopview.example.com
WECOM_FRONTEND_BASE_URL=https://shopview.example.com
# 企业微信通讯录同步范围。默认只同步百货条线与集团总裁办；如需全部同步可改为 *
WECOM_ALLOWED_DEPARTMENT_KEYWORDS=百货条线,集团总裁办
