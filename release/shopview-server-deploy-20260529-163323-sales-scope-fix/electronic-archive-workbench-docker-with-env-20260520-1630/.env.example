ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1
ORACLE_POOL_TIMEOUT=60
ORACLE_QUEUE_TIMEOUT=60000
ADMIN_PASSWORD=admin
DEFAULT_USER_PASSWORD=123456
APP_URL=http://da.princesky.com:3020
WECOM_ENABLED=true
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_APP_SECRET=
WECOM_REDIRECT_BASE_URL=http://da.princesky.com:3020
# 兼容旧配置：如已直接配置完整 callback，可继续使用 WECOM_REDIRECT_URI
# WECOM_CORP_SECRET=
# WECOM_REDIRECT_URI=http://da.princesky.com:3020/api/auth/wecom/callback

# OA 单据列映射：默认按当前 ETLKP.OA_BILL 结构读取
#   单据号 ob.sphbillno，门店 ob.store_id，类型 ob.type_01，申请人 ob.lastname
#   供应商/往来方 ob.supplier_name，部门 ob.departmentname，金额 ob.payment_amount，业务日期 ob.create_time
# 如其他环境列名不同，可覆盖为对应 Oracle 表达式。
# OA_BILL_DOC_NO_EXPR=ob.sphbillno
# OA_BILL_STORE_EXPR=ob.store_id
# OA_BILL_DOC_TYPE_EXPR=ob.type_01
# OA_BILL_AMOUNT_EXPR=ob.payment_amount
# OA_BILL_BUSINESS_DATE_EXPR=ob.create_time
# OA_BILL_APPLICANT_EXPR=ob.lastname
# OA_BILL_SUPPLIER_EXPR=ob.supplier_name
# OA_BILL_DEPT_EXPR=ob.departmentname
# 匹配表里 target_object_type 与默认“报销”不一致时覆盖（大小写不敏感）
# OA_BILL_TARGET_OBJECT_TYPE=报销
